# 토스증권 Open API 인증 정보
# 이 파일을 복사해서 .env 로 만들고 실제 값을 채우세요. (.env 는 git 에 올라가지 않습니다)

# 발급받은 클라이언트 ID (예: c_01HXYZ...)
TOSS_CLIENT_ID=

# 발급받은 클라이언트 시크릿 (예: s_xxxx...)
TOSS_CLIENT_SECRET=

# API 베이스 URL (기본값 사용 권장)
TOSS_BASE_URL=https://openapi.tossinvest.com

# 사용할 계좌 accountSeq. 비워두면 계좌 목록의 첫 번째 계좌를 자동 사용
TOSS_ACCOUNT_SEQ=

# --- 브로커 선택 (toss | kiwoom) ---
BROKER=toss

# --- 키움증권 REST (BROKER=kiwoom 일 때) ---
KIWOOM_APP_KEY=
KIWOOM_SECRET_KEY=
# 모의투자 서버 사용 시 true (KRX만 지원). 기본 false=실전
KIWOOM_PAPER=false

# --- 알림 (선택) ---
# 디스코드 웹훅 URL. 넣으면 실제 매수 체결 시 "샀어요!" 알림이 옴. 비우면 알림 없음.
# 디스코드 채널 → 설정 → 연동 → 웹후크 만들기 → URL 복사
DISCORD_WEBHOOK_URL=
